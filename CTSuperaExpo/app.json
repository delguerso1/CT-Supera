{
  "expo": {
    "name": "CT Supera",
    "slug": "CTSuperaExpo",
    "scheme": "ctsupera",
    "version": "1.0.8",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo-supera-principal.png",
      "resizeMode": "contain",
      "backgroundColor": "#1F6C86"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ctsupera.app",
      "buildNumber": "9"
    },
    "android": {
      "package": "com.ctsupera.superaapp",
      "googleServicesFile": "./google-services.json",
      "versionCode": 9,
      "softwareKeyboardLayoutMode": "resize",
      "usesCleartextTraffic": false,
      "notification": {
        "icon": "./assets/icon.png",
        "color": "#1F6C86"
      },
      "adaptiveIcon": {
        "backgroundColor": "#1F6C86",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1F6C86"
        }
      ],
      "./plugins/withFirebaseAndroid.js"
    ],
    "extra": {
      "eas": {
        "projectId": "f1baab53-bbd8-436a-b0ed-18389f501f59"
      }
    },
    "owner": "devra.group",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f1baab53-bbd8-436a-b0ed-18389f501f59"
    }
  }
}
